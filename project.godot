; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Godot Boilerplate"
config/description="A professional Godot 4.x game architecture boilerplate with singleton managers, lifecycle patterns, and signal-driven communication."
config/version="1.0.0"
run/main_scene="res://scenes/components/ExampleComponent/ExampleComponent.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="uid://c0xj3r0rcjojf"

[autoload]

EventBus="*res://scripts/systems/managers/EventBus.gd"
GameStateManager="*res://scripts/systems/managers/GameStateManager.gd"
TimerManager="*res://scripts/systems/managers/TimerManager.gd"
AudioManager="*res://scripts/systems/managers/AudioManager.gd"
Constants="*res://scripts/Constants.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[global_group]

Player=""
Enemy=""
Collectible=""
UI=""

[rendering]

textures/canvas_textures/default_texture_filter=0
